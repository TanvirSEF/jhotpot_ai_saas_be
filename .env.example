PROJECT_NAME="NexusSuite API"
API_V1_STR="/api/v1"

# sqlite+aiosqlite (dev) or postgresql+asyncpg://user:pass@host:5432/nexussuite
DATABASE_URL="sqlite+aiosqlite:///./nexussuite.db"

SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis (Celery broker & backend)
REDIS_URL="redis://default:your-password@your-host:6379"

# Fernet key for encrypting Meta Page Access Tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY="your-fernet-key-here"
