PROJECT_NAME="NexusSuite API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'

DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/nexussuite"

SECRET_KEY="change-me"
ALGORITHM="HS256"
JWT_ISSUER="nexussuite-api"
JWT_AUDIENCE="nexussuite-clients"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

REDIS_URL="redis://default:your-password@your-host:6379"
AUTH_RATE_LIMIT_IP_REQUESTS=30
AUTH_RATE_LIMIT_ACCOUNT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

FERNET_KEY="your-fernet-key-here"

OPENAI_API_KEY="your-openai-api-key"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_CHAT_MODEL="gpt-4o-mini"
RAG_MIN_SIMILARITY="0.55"
RAG_MAX_INPUT_CHARS="2000"
RAG_MAX_CONTEXT_CHARS="6000"
RESUME_EXPORT_STORAGE_PATH="storage/resume_exports"
RESUME_EXPORT_RECOVERY_SECONDS=180
HEALTHCHECK_TIMEOUT_SECONDS="2.0"
METRICS_ENABLED=true

META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_VERIFY_TOKEN="replace-with-a-private-webhook-verify-token"

BACKEND_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:3000"
